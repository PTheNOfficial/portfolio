---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout title="Home | PTheN's Portfolio">
  <section class="min-h-screen flex flex-col justify-center items-center text-center p-8">
    <h1 class="text-6xl font-bold mb-6">"PTheN"</h1>
    <p class="text-2xl mb-8 max-w-2xl">
      Web developer in formation | Enamored with technology and design.
    </p>
    <a href="#projects" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg transition-colors">Projects</a>
  </section>

  <section id="aboutme" class="py-16">
    <h2 class="text-3xl font-bold mb-6">About</h2>
    <p class="max-w-3xl">Just a guy with an insatiable desire of learning and exploring interesting topics.</p>
  </section>

  <section id="projects" class="py-16">
    <h2 class="text-3xl font-bold mb-6">Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <Card
      title="Project #1"
      description="Project description"
      />
      <Card
      title="Project #2"
      description="Project description"
      />
      <Card
      title="Project #3"
      description="Project description"
      />
      <Card
      title="Project #4"
      description="Project description"
      />
      <Card
      title="Project #5"
      description="Project description"
      />
    </div>
  </section>
</Layout>
